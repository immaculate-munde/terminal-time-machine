{
  "name": "@munde-codes/terminal-time-machine",
  "version": "1.0.0",
  "description": "An interactive git timeline with AI summaries",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "time-machine": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild index.jsx --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\" --external:ink --external:react --external:simple-git --external:@google/generative-ai --external:@azure-rest/ai-inference --external:@azure/core-auth --external:dotenv",
    "prepublishOnly": "npm run build",
    "start": "tsx index.jsx",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/immaculate-munde/terminal-time-machine.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/immaculate-munde/terminal-time-machine/issues"
  },
  "homepage": "https://github.com/immaculate-munde/terminal-time-machine#readme",
  "dependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "ink": "^7.0.0",
    "react": "^19.2.5",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  }
}
